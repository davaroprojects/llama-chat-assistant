{
  "name": "prrrrr",
  "displayName": "%ext.displayName%",
  "description": "%ext.description%",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "icon": "resources/marketplace-icon.png",
  "contributes": {
    "configuration": [
      {
        "title": "%config.chat.title%",
        "properties": {
          "llamaChat.chat.temperature": {
            "type": "number",
            "default": 0.2,
            "minimum": 0,
            "maximum": 2,
            "description": "%config.temperature.description%"
          },
          "llamaChat.chat.model": {
            "type": "string",
            "default": "local",
            "description": "%config.model.description%"
          },
          "llamaChat.chat.maxTokens": {
            "type": "number",
            "default": 2048,
            "minimum": 1,
            "maximum": 16384,
            "description": "%config.maxTokens.description%"
          },
          "llamaChat.chat.debug": {
            "type": "boolean",
            "default": false,
            "description": "%config.debug.description%"
          },
          "llamaChat.chat.maxAttachedFileSizeKb": {
            "type": "number",
            "default": 256,
            "minimum": 1,
            "maximum": 4096,
            "description": "%config.maxAttachedFileSizeKb.description%"
          },
          "llamaChat.chat.directLlmTemplate": {
            "type": "object",
            "default": {},
            "description": "%config.chat.directLlmTemplate.description%"
          },
          "llamaChat.chat.globalReactTemplate": {
            "type": "object",
            "default": {},
            "description": "%config.chat.globalReactTemplate.description%"
          },
          "llamaChat.chat.localRagTemplate": {
            "type": "object",
            "default": {},
            "description": "%config.chat.localRagTemplate.description%"
          },
          "llamaChat.chat.deepReactTemplate": {
            "type": "object",
            "default": {},
            "description": "%config.chat.deepReactTemplate.description%"
          },
          "llamaChat.chat.ragModeTemplate": {
            "type": "object",
            "default": {},
            "description": "%config.chat.ragModeTemplate.description%"
          },
          "llamaChat.chat.specificFilesModeTemplate": {
            "type": "object",
            "default": {},
            "description": "%config.chat.specificFilesModeTemplate.description%"
          }
        }
      },
      {
        "title": "%config.llamaCpp.title%",
        "properties": {
          "llamaChat.llamaCpp.executablePath": {
            "type": "string",
            "default": "./build/bin/llama-server",
            "description": "%config.server.executablePath.description%"
          },
          "llamaChat.llamaCpp.modelPath": {
            "type": "string",
            "default": "./models/qwen2.5-coder-7b-instruct-q4_k_m.gguf",
            "description": "%config.server.modelPath.description%"
          },
          "llamaChat.llamaCpp.gpuLayers": {
            "type": "number",
            "default": 99,
            "description": "%config.server.gpuLayers.description%"
          },
          "llamaChat.llamaCpp.contextSize": {
            "type": "number",
            "default": 16384,
            "minimum": 1,
            "description": "%config.server.contextSize.description%"
          },
          "llamaChat.llamaCpp.flashAttention": {
            "type": "boolean",
            "default": true,
            "description": "%config.server.flashAttention.description%"
          },
          "llamaChat.llamaCpp.host": {
            "type": "string",
            "default": "127.0.0.1",
            "description": "%config.server.host.description%"
          },
          "llamaChat.llamaCpp.port": {
            "type": "number",
            "default": 8033,
            "minimum": 1,
            "maximum": 65535,
            "description": "%config.server.port.description%"
          },
          "llamaChat.llamaCpp.chatCompletionsPath": {
            "type": "string",
            "default": "/v1/chat/completions",
            "description": "%config.server.chatCompletionsPath.description%"
          },
          "llamaChat.llamaCpp.jinja": {
            "type": "boolean",
            "default": true,
            "description": "%config.server.jinja.description%"
          },
          "llamaChat.llamaCpp.tools": {
            "type": "string",
            "default": "all",
            "description": "%config.server.tools.description%"
          }
        }
      },
      {
        "title": "%config.chromaDb.title%",
        "properties": {
          "llamaChat.chromaDb.url": {
            "type": "string",
            "default": "http://127.0.0.1",
            "description": "%config.rag.chromaUrl.description%"
          },
          "llamaChat.chromaDb.port": {
            "type": "number",
            "default": 8000,
            "minimum": 1,
            "maximum": 65535,
            "description": "%config.rag.chromaPort.description%"
          },
          "llamaChat.chromaDb.collectionPrefix": {
            "type": "string",
            "default": "llama-chat-ephemeral",
            "description": "%config.rag.collectionPrefix.description%"
          },
          "llamaChat.chromaDb.excludeDirs": {
            "type": "array",
            "default": [
              ".git",
              ".gradle",
              ".idea",
              "node_modules",
              "dist",
              "out",
              "build",
              "coverage",
              "target",
              ".vscode"
            ],
            "items": {
              "type": "string"
            },
            "description": "%config.rag.excludeDirs.description%"
          },
          "llamaChat.chromaDb.excludeFileGlobs": {
            "type": "array",
            "default": [
              "**/*.bin",
              "**/*.class",
              "**/*.jar",
              "**/*.lock"
            ],
            "items": {
              "type": "string"
            },
            "description": "%config.rag.excludeFileGlobs.description%"
          },
          "llamaChat.chromaDb.maxFileSizeKb": {
            "type": "number",
            "default": 512,
            "minimum": 1,
            "description": "%config.rag.maxFileSizeKb.description%"
          },
          "llamaChat.chromaDb.maxIndexedFiles": {
            "type": "number",
            "default": 2000,
            "minimum": 1,
            "description": "%config.rag.maxIndexedFiles.description%"
          },
          "llamaChat.chromaDb.chunkSizeChars": {
            "type": "number",
            "default": 2000,
            "minimum": 200,
            "description": "%config.rag.chunkSizeChars.description%"
          },
          "llamaChat.chromaDb.chunkOverlapChars": {
            "type": "number",
            "default": 300,
            "minimum": 0,
            "description": "%config.rag.chunkOverlapChars.description%"
          },
          "llamaChat.chromaDb.vectorCandidatePool": {
            "type": "number",
            "default": 50,
            "minimum": 1,
            "description": "%config.rag.vectorCandidatePool.description%"
          },
          "llamaChat.chromaDb.maxQueryResults": {
            "type": "number",
            "default": 12,
            "minimum": 1,
            "description": "%config.rag.maxQueryResults.description%"
          },
          "llamaChat.chromaDb.minCosineSimilarity": {
            "type": "number",
            "default": 0.2,
            "minimum": 0,
            "maximum": 1,
            "description": "%config.rag.minCosineSimilarity.description%"
          }
        }
      },
      {
        "title": "%config.memory.title%",
        "properties": {
          "llamaChat.memory.contextWindowSize": {
            "type": "number",
            "default": 8192,
            "minimum": 1024,
            "description": "%config.memory.contextWindowSize.description%"
          },
          "llamaChat.memory.safetyThreshold": {
            "type": "number",
            "default": 6500,
            "minimum": 512,
            "description": "%config.memory.safetyThreshold.description%"
          },
          "llamaChat.memory.preserveSystemPrompt": {
            "type": "boolean",
            "default": true,
            "description": "%config.memory.preserveSystemPrompt.description%"
          },
          "llamaChat.memory.preserveRecentMessagesCount": {
            "type": "number",
            "default": 2,
            "minimum": 1,
            "description": "%config.memory.preserveRecentMessagesCount.description%"
          }
        }
      }
    ],
    "commands": [
      {
        "command": "prrrrr.openSettings",
        "title": "%command.openSettings.title%",
        "icon": "settings-gear"
      },
      {
        "command": "prrrrr.moveSidebarRight",
        "title": "%command.moveSidebarRight.title%",
        "icon": "arrow-right"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "prrrrr-sidebar",
          "title": "%views.container.title%",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "prrrrr-sidebar": [
        {
          "type": "webview",
          "id": "prrrrr-view",
          "name": "%views.chat.name%"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "prrrrr.openSettings",
          "when": "view == prrrrr-view",
          "group": "$(navigation)"
        },
        {
          "command": "prrrrr.moveSidebarRight",
          "when": "view == prrrrr-view",
          "group": "navigation@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "copy-media": "node -e \"const fs=require('fs'); fs.mkdirSync('dist/media', {recursive:true}); fs.copyFileSync('media/webview.html', 'dist/media/webview.html'); fs.copyFileSync('media/webview.css', 'dist/media/webview.css'); fs.copyFileSync('media/webview.js', 'dist/media/webview.js'); fs.copyFileSync('media/prism.min.js', 'dist/media/prism.min.js'); fs.copyFileSync('media/marked.min.js', 'dist/media/marked.min.js');\"",
    "compile": "npm run check-types && npm run lint && node esbuild.js && npm run copy-media",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production && npm run copy-media",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.1",
    "@huggingface/transformers": "^4.2.0",
    "@langchain/textsplitters": "^1.0.1",
    "chromadb": "^3.4.3",
    "js-tiktoken": "^1.0.21"
  }
}
