{
  "name": "la-llama-chat",
  "publisher": "davaro",
  "displayName": "%ext.displayName%",
  "description": "%ext.description%",
  "version": "0.0.4",
  "license": "GPL-3.0-or-later",
  "engines": {
    "node": ">=24.0.0",
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "icon": "resources/marketplace-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/davaroprojects/llama-chat-assistant.git"
  },
  "contributes": {
    "configuration": [
      {
        "title": "%config.chat.title%",
        "properties": {
          "laLlamaChat.chat.temperature": {
            "type": "number",
            "default": 0.2,
            "minimum": 0,
            "maximum": 2,
            "description": "%config.temperature.description%"
          },
          "laLlamaChat.chat.model": {
            "type": "string",
            "default": "local",
            "description": "%config.model.description%"
          },
          "laLlamaChat.chat.maxTokens": {
            "type": "number",
            "default": 2048,
            "minimum": 1,
            "maximum": 16384,
            "description": "%config.maxTokens.description%"
          },
          "laLlamaChat.chat.debug": {
            "type": "boolean",
            "default": false,
            "description": "%config.debug.description%"
          },
          "laLlamaChat.chat.maxAttachedFileSizeKb": {
            "type": "number",
            "default": 256,
            "minimum": 1,
            "maximum": 4096,
            "description": "%config.maxAttachedFileSizeKb.description%"
          },
          "laLlamaChat.chat.directLlmTemplate": {
            "type": "object",
            "default": {},
            "description": "%config.chat.directLlmTemplate.description%"
          },
          "laLlamaChat.chat.globalReactTemplate": {
            "type": "object",
            "default": {},
            "description": "%config.chat.globalReactTemplate.description%"
          },
          "laLlamaChat.chat.localRagTemplate": {
            "type": "object",
            "default": {},
            "description": "%config.chat.localRagTemplate.description%"
          },
          "laLlamaChat.chat.deepReactTemplate": {
            "type": "object",
            "default": {},
            "description": "%config.chat.deepReactTemplate.description%"
          },
          "laLlamaChat.chat.ragModeTemplate": {
            "type": "object",
            "default": {},
            "description": "%config.chat.ragModeTemplate.description%"
          },
          "laLlamaChat.chat.specificFilesModeTemplate": {
            "type": "object",
            "default": {},
            "description": "%config.chat.specificFilesModeTemplate.description%"
          }
        }
      },
      {
        "title": "%config.llamaCpp.title%",
        "properties": {
          "laLlamaChat.llamaCpp.executablePath": {
            "type": "string",
            "default": "./build/bin/llama-server",
            "description": "%config.server.executablePath.description%"
          },
          "laLlamaChat.llamaCpp.modelPath": {
            "type": "string",
            "default": "./models/qwen2.5-coder-7b-instruct-q4_k_m.gguf",
            "description": "%config.server.modelPath.description%"
          },
          "laLlamaChat.llamaCpp.gpuLayers": {
            "type": "number",
            "default": 99,
            "description": "%config.server.gpuLayers.description%"
          },
          "laLlamaChat.llamaCpp.contextSize": {
            "type": "number",
            "default": 16384,
            "minimum": 1,
            "description": "%config.server.contextSize.description%"
          },
          "laLlamaChat.llamaCpp.flashAttention": {
            "type": "boolean",
            "default": true,
            "description": "%config.server.flashAttention.description%"
          },
          "laLlamaChat.llamaCpp.host": {
            "type": "string",
            "default": "127.0.0.1",
            "description": "%config.server.host.description%"
          },
          "laLlamaChat.llamaCpp.port": {
            "type": "number",
            "default": 8033,
            "minimum": 1,
            "maximum": 65535,
            "description": "%config.server.port.description%"
          },
          "laLlamaChat.llamaCpp.chatCompletionsPath": {
            "type": "string",
            "default": "/v1/chat/completions",
            "description": "%config.server.chatCompletionsPath.description%"
          },
          "laLlamaChat.llamaCpp.jinja": {
            "type": "boolean",
            "default": true,
            "description": "%config.server.jinja.description%"
          },
          "laLlamaChat.llamaCpp.tools": {
            "type": "string",
            "default": "all",
            "description": "%config.server.tools.description%"
          }
        }
      },
      {
        "title": "%config.chromaDb.title%",
        "properties": {
          "laLlamaChat.chromaDb.url": {
            "type": "string",
            "default": "http://127.0.0.1",
            "description": "%config.rag.chromaUrl.description%"
          },
          "laLlamaChat.chromaDb.port": {
            "type": "number",
            "default": 8000,
            "minimum": 1,
            "maximum": 65535,
            "description": "%config.rag.chromaPort.description%"
          },
          "laLlamaChat.chromaDb.excludeDirs": {
            "type": "array",
            "default": [
              ".git",
              ".gradle",
              ".idea",
              "node_modules",
              "dist",
              "out",
              "build",
              "coverage",
              "target",
              ".vscode"
            ],
            "items": {
              "type": "string"
            },
            "description": "%config.rag.excludeDirs.description%"
          },
          "laLlamaChat.chromaDb.excludeFileGlobs": {
            "type": "array",
            "default": [
              "**/*.bin",
              "**/*.class",
              "**/*.jar",
              "**/*.lock"
            ],
            "items": {
              "type": "string"
            },
            "description": "%config.rag.excludeFileGlobs.description%"
          },
          "laLlamaChat.chromaDb.maxFileSizeKb": {
            "type": "number",
            "default": 512,
            "minimum": 1,
            "description": "%config.rag.maxFileSizeKb.description%"
          },
          "laLlamaChat.chromaDb.maxIndexedFiles": {
            "type": "number",
            "default": 2000,
            "minimum": 1,
            "description": "%config.rag.maxIndexedFiles.description%"
          },
          "laLlamaChat.chromaDb.targetChunkTokens": {
            "type": "number",
            "default": 350,
            "minimum": 32,
            "description": "%config.rag.targetChunkTokens.description%"
          },
          "laLlamaChat.chromaDb.maxChunkTokens": {
            "type": "number",
            "default": 512,
            "minimum": 64,
            "description": "%config.rag.maxChunkTokens.description%"
          },
          "laLlamaChat.chromaDb.minChunkTokens": {
            "type": "number",
            "default": 120,
            "minimum": 1,
            "description": "%config.rag.minChunkTokens.description%"
          },
          "laLlamaChat.chromaDb.fallbackChunkTokens": {
            "type": "number",
            "default": 300,
            "minimum": 32,
            "description": "%config.rag.fallbackChunkTokens.description%"
          },
          "laLlamaChat.chromaDb.vectorCandidatePool": {
            "type": "number",
            "default": 50,
            "minimum": 1,
            "description": "%config.rag.vectorCandidatePool.description%"
          },
          "laLlamaChat.chromaDb.maxQueryResults": {
            "type": "number",
            "default": 12,
            "minimum": 1,
            "description": "%config.rag.maxQueryResults.description%"
          },
          "laLlamaChat.chromaDb.minCosineSimilarity": {
            "type": "number",
            "default": 0.2,
            "minimum": 0,
            "maximum": 1,
            "description": "%config.rag.minCosineSimilarity.description%"
          },
          "laLlamaChat.chromaDb.rerankEnabled": {
            "type": "boolean",
            "default": true,
            "description": "%config.rag.rerankEnabled.description%"
          },
          "laLlamaChat.chromaDb.rerankTimeoutMs": {
            "type": "number",
            "default": 5000,
            "minimum": 1000,
            "maximum": 30000,
            "description": "%config.rag.rerankTimeoutMs.description%"
          },
          "laLlamaChat.chromaDb.rerankFallbackToHybrid": {
            "type": "boolean",
            "default": true,
            "description": "%config.rag.rerankFallbackToHybrid.description%"
          }
        }
      },
      {
        "title": "%config.memory.title%",
        "properties": {
          "laLlamaChat.memory.contextWindowSize": {
            "type": "number",
            "default": 8192,
            "minimum": 1024,
            "description": "%config.memory.contextWindowSize.description%"
          },
          "laLlamaChat.memory.safetyThreshold": {
            "type": "number",
            "default": 6500,
            "minimum": 512,
            "description": "%config.memory.safetyThreshold.description%"
          },
          "laLlamaChat.memory.preserveSystemPrompt": {
            "type": "boolean",
            "default": true,
            "description": "%config.memory.preserveSystemPrompt.description%"
          },
          "laLlamaChat.memory.preserveRecentMessagesCount": {
            "type": "number",
            "default": 2,
            "minimum": 1,
            "description": "%config.memory.preserveRecentMessagesCount.description%"
          }
        }
      }
    ],
    "commands": [
      {
        "command": "laLlamaChat.openSettings",
        "title": "%command.openSettings.title%",
        "icon": "settings-gear"
      },
      {
        "command": "laLlamaChat.moveSidebarRight",
        "title": "%command.moveSidebarRight.title%",
        "icon": "arrow-right"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "llama-chat-assistant-sidebar",
          "title": "%views.container.title%",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "llama-chat-assistant-sidebar": [
        {
          "type": "webview",
          "id": "llama-chat-assistant-view",
          "name": "%views.chat.name%"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "laLlamaChat.openSettings",
          "when": "view == llama-chat-assistant-view",
          "group": "$(navigation)"
        },
        {
          "command": "laLlamaChat.moveSidebarRight",
          "when": "view == llama-chat-assistant-view",
          "group": "navigation@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "copy-media": "node scripts/copy-dist-assets.js",
    "compile": "npm run check-types && npm run lint && node esbuild.js && npm run copy-media",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production && npm run copy-media",
    "compile-tests": "tsc -p tsconfig.test.json",
    "watch-tests": "tsc -p tsconfig.test.json -w",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@eidentic/transformers": "^0.1.4",
    "@hey-api/client-fetch": "^0.13.1",
    "@huggingface/transformers": "^4.2.0",
    "@langchain/core": "^1.2.1",
    "@lumis-sh/wasm-json": "^0.26.2",
    "@lumis-sh/wasm-xml": "^0.26.1",
    "@lumis-sh/wasm-yaml": "^0.26.0",
    "@vscode/tree-sitter-wasm": "^0.3.1",
    "chromadb": "^3.4.3",
    "dompurify": "^3.4.11",
    "js-tiktoken": "^1.0.21",
    "web-tree-sitter": "^0.26.9"
  }
}
